# Environment Configuration for Food Nutrition Intelligence RAG
# Copy this file to .env and fill in your API keys

# IMPORTANT: Add your Groq API key below
# Get your free API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Groq Model Options (updated for current support):
# llama-3.3-70b-versatile (recommended - latest 70B model)
# llama-3.1-8b-instant (fastest, lower memory)
# mixtral-8x7b-32768 (good balance)
GROQ_MODEL=llama-3.3-70b-versatile

# Dataset Configuration
# CSV_PATH: Optional path to foods_cleaned.csv (for non-standard locations)
# If not set, the app will search in:
#   1. Same directory as data_loader.py
#   2. Current working directory
#   3. Environment variable CSV_PATH
# CSV_PATH=/path/to/foods_cleaned.csv
